class Panda < Formula
  desc "macOS tiling window manager written in Zig"
  homepage "https://getpanda.dev"
  url "__PANDA_URL__"
  sha256 "__PANDA_SHA256__"
  version "__PANDA_VERSION__"

  def install
    bin.install "panda"
  end

  test do
    assert_match "panda commands:", shell_output("#{bin}/panda help")
  end
end
